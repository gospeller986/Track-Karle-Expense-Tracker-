{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://track-karle-expense-tracker.onrender.com/api/v1"
      }
    },
    "preview-arm64": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "GRADLE_OPTS": "-Pandroid.abiSplits.enable=true -Pandroid.abiFilters=arm64-v8a"
        }
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://track-karle-expense-tracker.onrender.com/api/v1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://track-karle-expense-tracker.onrender.com/api/v1"
      }
    }
  }
}
